---
import { API_URL } from 'astro:env/server';
import Layout from "../layouts/Layout.astro";
import Image from 'astro/components/Image.astro'
import LogoIcon from '../assets/members_icon.svg'

// 1. Grab the token from the URL query parameters (e.g., ?token=abc)
const token = Astro.url.searchParams.get('token');
let errorMessage = "";
let successMessage = "";

// If there's no token in the URL, they shouldn't be here
if (!token && Astro.request.method === "GET") {
  return Astro.redirect("/signin");
}

// 2. Handle the form submission
if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const newPassword = data.get("password");
    const confirmPassword = data.get("confirm_password");

    // Safety check on the frontend
    if (newPassword !== confirmPassword) {
      errorMessage = "Passwords do not match.";
    } else {
      // 3. Send the token and new password to FastAPI
      const response = await fetch(`${API_URL}/auth/set-password`, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          token: token,
          new_password: newPassword
        })
      });

      if (!response.ok) {
        const errorData = await response.json();
        // This will display "Token expired" if they waited longer than 24 hours
        errorMessage = errorData.detail || "Failed to reset password. The link may be invalid or expired.";
      } else {
        successMessage = "Your password has been successfully set! You can close this window and sign in.";
      }
    }
  } catch (error) {
    console.error("Password reset error:", error);
    errorMessage = "An unexpected error occurred.";
  }
}
---

<Layout>
    <main class="font-main">
        <div class="flex flex-col gap-5 left-right-padding pt-24 lg:pt-20">
            <div class="flex pt-14 pb-6">
                <div class="prose max-w-5xl">
                    <Image src={LogoIcon} alt="" width=80 height=80 class="" />
                    <h1 class="font-normal mb-[0.3em]">
                        ¡Bienvenido a <span class="text-(--secondary-color)">Members</span>!
                    </h1>
                    <p class="mt-0">Asigna una contraseña para completar el registro de tu cuenta de Members y acceder a tus beneficios.</p>
                </div>
            </div>
            {errorMessage && (
                    <div class="bg-red-50 text-red-600 p-3 rounded-md text-sm mb-4 text-center border border-red-100">
                      {errorMessage}
                    </div>
                  )}

                  {successMessage ? (
                    <div class="flex flex-col justify-center items-center bg-green-50 text-green-700 p-4 rounded-md text-center font-medium border border-green-200">
                      {successMessage}
                    </div>
                    <div class="flex justify-center items-center">
                        <a href="https://members.seaviewmagazine.com/signin" class="w-full py-2.5 px-3.5 rounded-(--rounded-button) transition-colors ease-in-out no-underline bg-(--primary-color) hover:bg-(--secondary-color) text-white text-center">
                            Iniciar Sesión
                        </a>
                    </div>
                  ) : (
                    <form method="POST" class="space-y-4">

                      <div>
                        <label for="password" class="font-medium text-gray-700 mb-1">Nueva Contraseña</label>
                        <input
                          type="password"
                          id="password"
                          name="password"
                          required
                          minlength="8"
                          class="w-full px-4 py-2 rounded-(--rounded-button) border border-(--border-color) focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-(--primary-color)"
                        />
                      </div>

                      <div>
                        <label for="confirm_password" class="font-medium text-gray-700 mb-1">Confirmar Contraseña</label>
                        <input
                          type="password"
                          id="confirm_password"
                          name="confirm_password"
                          required
                          minlength="8"
                          class="w-full px-4 py-2 rounded-(--rounded-button) border border-(--border-color) focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-(--primary-color)"
                        />
                      </div>
                      <button type="submit" class="w-full py-2.5 px-3.5 mt-2 rounded-(--rounded-button) transition-colors ease-in-out no-underline bg-(--primary-color) hover:bg-(--secondary-color) text-white cursor-pointer">
                          Confirmar Contraseña
                      </button>

                    </form>
                  )}
                <div class="flex flex-col justify-center items-center mt-4">
                    <a href="https://wa.me/13223799602" class="no-underline hover:underline decoration-gray-600">
                        <p class="text-gray-600">¿Algún problema? Contáctanos y te ayudaremos</p>
                    </a>
                    <div class="m-8">
                        <p class="text-[14px] sm:text-[16px] text-gray-600">Hecho con 💚 por Beyond</p>
                    </div>
                </div>
        </div>
    </main>
</Layout>
