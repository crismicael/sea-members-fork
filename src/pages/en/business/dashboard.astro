---
import { getAbsoluteLocaleUrl } from "astro:i18n";
import { useTranslation } from "../../../i18n/utils"
import { API_URL } from 'astro:env/server';
import type { languageList } from "../../../i18n/ui";
import Layout from "../../../layouts/Layout.astro";
import HeaderBusinessDashboard from "../../../components/dashboard/HeaderBusinessDashboard.astro";
import FooterBusinessDashboard from "../../../components/dashboard/FooterBusinessDashboard.astro";
import Image from 'astro/components/Image.astro'
import Language from "../../../components/ui/Language.astro";
const currentLang = Astro.currentLocale || 'en';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);

type Coupon = {
  name: string;
  description: string;
  img_url: string;
  cooldown_days: number;
  max_redemptions: number;
  valid_from: string;
  valid_to: string;
  is_active: boolean;
};


// 1. Get the custom JWT token from the user's cookies
const businessTokenCookie = Astro.cookies.get("business_jwt");

// 2. If the user isn't logged in, redirect them back to the login page
if (!businessTokenCookie) {
  return Astro.redirect("/en/business/signin");
}

const token = businessTokenCookie.value;

let profile = null;
let coupons: Coupon[] = [];

try {
  // 3. Fetch the Client Profile (Step 13 from our prompt)
  const profileResponse = await fetch(`${API_URL}/businesses/me`, {
    method: "GET",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${token}` // Pass the JWT in the header
    }
  });

  if (profileResponse.status === 401) {
    // Token is invalid or expired
    Astro.cookies.delete("business_jwt");
    return Astro.redirect("/en/business/signin");
  }

  profile = await profileResponse.json();

  // 4. Fetch the Business's Coupons
  const couponsResponse = await fetch(`${API_URL}/businesses/coupons`, {
    method: "GET",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${token}`
    }
  });

  if (couponsResponse.ok) {
    coupons = await couponsResponse.json();
  }

} catch (error) {
  console.error("Error:", error);
}

const activeCoupons: Coupon[] = coupons.filter((coupon) => coupon.is_active);
const inactiveCoupons: Coupon[] = coupons.filter((coupon) => !coupon.is_active);
---

<Layout>
  <HeaderBusinessDashboard />
  <main class="font-main">
    <div class="left-right-padding up-down-padding mx-auto pt-24 lg:pt-28 max-w-6xl border-x border-(--border-color) prose">
        <div class="flex justify-between">
            <h1 class="text-[22px] md:text-[2.25em]">{translateLabels("businessDashboard.welcome")}, {profile?.name ?? "Usuario"}!</h1>
            <div id="business-dashboard-button-header">
                <Language color="black">
                    <span class="absolute inline-flex items-center justify-center h-full w-full rounded-full -top-3 -right-3 bg-black text-white text-[12px]">{translateLabels("footer.languageIcon")}</span>
                </Language>
            </div>
            <div id="business-dashboard-popper-header" role="tooltip" class="hidden z-30">
                <div class="popover-content w-48 p-4 bg-white border border-gray-300 rounded-[10px] shadow-lg flex flex-col">
                    <a href="/en/business/dashboard" class="no-underline flex gap-3 py-2 px-3 rounded-[10px] hover:bg-gray-500/10"><span class="font-bold uppercase">en</span><span>English</span></a>
                    <a href="/business/dashboard" class="no-underline flex gap-3 py-2 px-3 rounded-[10px] hover:bg-gray-500/10"><span class="font-bold uppercase">es</span><span>Español</span></a>
                </div>
            </div>
        </div>
      <p class="font-main">{translateLabels("businessDashboard.subtitle")} "{profile.name}":</p>
      {coupons.length === 0 ? (
        <p>No coupons available at this time.</p>
      ) : (
        <div class="flex flex-col gap-8">
          <section>
            <div class="grid grid-cols-2 sm:grid-cols-3 3xl:grid-cols-4 gap-4">
              {activeCoupons.length === 0 ? (
                <p>No hay cupones activos.</p>
              ) : (
                activeCoupons.map((coupon: Coupon) => (
                  <div>
                    <div>
                      <Image src={coupon.img_url} alt={coupon.name} width="500" height="500" draggable="false" class="rounded-2xl m-0" />
                    </div>
                    <div>
                      <h4>{coupon.name}</h4>
                      <p>{coupon.description}</p>
                      <div class="flex flex-col *:text-xs">
                        <span>{translateLabels("businessDashboard.time")} {coupon.cooldown_days} días</span>
                        <span>{translateLabels("businessDashboard.max_redemptions")} {coupon.max_redemptions}</span>
                        <span>{translateLabels("businessDashboard.valid_from")} {coupon.valid_from}</span>
                        <span>{translateLabels("businessDashboard.valid_to")} {coupon.valid_to}</span>
                      </div>
                    </div>
                  </div>
                ))
              )}
            </div>
          </section>
          <section>
            <h3 class="mt-0">Cupones inactivos</h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 3xl:grid-cols-4 gap-4">
              {inactiveCoupons.length === 0 ? (
                <p>No hay cupones inactivos.</p>
              ) : (
                inactiveCoupons.map((coupon: Coupon) => (
                  <div>
                    <div>
                      <Image src={coupon.img_url} alt={coupon.name} width="500" height="500" draggable="false" class="rounded-2xl m-0" />
                    </div>
                    <div>
                      <h4>{coupon.name}</h4>
                      <p>{coupon.description}</p>
                    </div>
                  </div>
                ))
              )}
            </div>
          </section>
        </div>
      )}
    </div>
  </main>
  <FooterBusinessDashboard />
  <script>
      import { createPopper } from "@popperjs/core";

      const button = document.getElementById("business-dashboard-button-header");
      const popper = document.getElementById("business-dashboard-popper-header");

      let popperInstance: ReturnType<typeof createPopper> | null = null;
      let hideTimeout: ReturnType<typeof setTimeout> | null = null;

      function show() {
          if (!button || !popper) return;

          if (hideTimeout) {
              clearTimeout(hideTimeout);
              hideTimeout = null;
          }

          popper.classList.remove("hidden");
          popperInstance = createPopper(button, popper, {
              placement: "left-start",
              modifiers: [
                  {
                      name: "offset",
                      options: {
                          offset: [0, 8],
                      },
                  },
              ],
          });
      }

      function hide() {
          if (!popper) return;

          hideTimeout = setTimeout(() => {
              popper.classList.add("hidden");

              if (popperInstance) {
                  popperInstance.destroy();
                  popperInstance = null;
              }
          }, 100);
      }

      if (button && popper) {
          button.addEventListener('mouseenter', show);
          button.addEventListener('mouseleave', hide);
          popper.addEventListener('mouseenter', show);
          popper.addEventListener('mouseleave', hide);
      }
  </script>
</Layout>
