---
import { useTranslation } from "../../i18n/utils"
import type { languageList } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
const currentLang = Astro.currentLocale || 'en';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);
---

<Layout>
  <Header />
  <main class="font-secondary">
    <div class="left-right-padding up-down-padding mx-auto pt-24 lg:pt-28 max-w-4xl border-x border-(--border-color) prose">
        <h1 class="font-main text-center">{translateLabels("termsConditions.title")}</h1>
        <p>
            {translateLabels("termsConditions.textIntro")}
        </p>
        <h2 class="font-main">{translateLabels("termsConditions.sections.01.title")}</h2>
        <p>
            {translateLabels("termsConditions.sections.01.text")}
        </p>
        <h2 class="font-main">{translateLabels("termsConditions.sections.02.title")}</h2>
        <p>
            {translateLabels("termsConditions.sections.02.text")}
        </p>
        <ul>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.02.termsConditionsSection02BulletPoints.01.title")}
                </span>
                {translateLabels("termsConditions.sections.02.termsConditionsSection02BulletPoints.01.text")}
            </li>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.02.termsConditionsSection02BulletPoints.02.title")}
                </span>
                {translateLabels("termsConditions.sections.02.termsConditionsSection02BulletPoints.02.text")}
            </li>
        </ul>
        <h2 class="font-main">{translateLabels("termsConditions.sections.03.title")}</h2>
        <p>
            {translateLabels("termsConditions.sections.03.text")}
        </p>
        <ul>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.03.termsConditionsSection03BulletPoints.01.title")}
                </span>
                {translateLabels("termsConditions.sections.03.termsConditionsSection03BulletPoints.01.text")}
            </li>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.03.termsConditionsSection03BulletPoints.02.title")}
                </span>
                {translateLabels("termsConditions.sections.03.termsConditionsSection03BulletPoints.02.text")}
            </li>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.03.termsConditionsSection03BulletPoints.03.title")}
                </span>
                {translateLabels("termsConditions.sections.03.termsConditionsSection03BulletPoints.03.text")}
            </li>
        </ul>
        <h2 class="font-main">{translateLabels("termsConditions.sections.04.title")}</h2>
        <p>
            {translateLabels("termsConditions.sections.04.text")}
        </p>
        <ul>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.04.termsConditionsSection04BulletPoints.01.title")}
                </span>
                {translateLabels("termsConditions.sections.04.termsConditionsSection04BulletPoints.01.text")}
            </li>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.04.termsConditionsSection04BulletPoints.02.title")}
                </span>
                {translateLabels("termsConditions.sections.04.termsConditionsSection04BulletPoints.02.text")}
            </li>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.04.termsConditionsSection04BulletPoints.03.title")}
                </span>
                {translateLabels("termsConditions.sections.04.termsConditionsSection04BulletPoints.03.text")}
            </li>
        </ul>
        <h2 class="font-main">{translateLabels("termsConditions.sections.05.title")}</h2>
        <p>
            {translateLabels("termsConditions.sections.05.text")}
        </p>
        <ul>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.05.termsConditionsSection05BulletPoints.01.title")}
                </span>
                {translateLabels("termsConditions.sections.05.termsConditionsSection05BulletPoints.01.text")}
            </li>
            <li>
                <span class="font-bold">
                    {translateLabels("termsConditions.sections.05.termsConditionsSection05BulletPoints.02.title")}
                </span>
                {translateLabels("termsConditions.sections.05.termsConditionsSection05BulletPoints.02.text")}
            </li>
        </ul>
        <p>{translateLabels("termsConditions.lastUpdated")}</p>
    </div>
  </main>
  <Footer />
</Layout>
