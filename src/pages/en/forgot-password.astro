---
import type { languageList } from "../../i18n/ui";
import { getRelativeLocaleUrl, getAbsoluteLocaleUrl } from "astro:i18n";
import { useTranslation } from "../../i18n/utils"
import { API_URL } from 'astro:env/server';
import Layout from "../../layouts/Layout.astro";
import Image from 'astro/components/Image.astro'
import LogoIcon from '../../assets/members_icon.svg'
import LeftArrow from '../../assets/left-arrow.svg'
const currentLang = Astro.currentLocale || 'en';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);

let errorMessage = "";
let successMessage = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const email = data.get("email");

    const response = await fetch(`${API_URL}/auth/forgot-password`, {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ email: email })
    });

    if (!response.ok) {
      errorMessage = "An unexpected error occurred. Please try again later.";
    } else {
      // The backend returns a generic success message regardless of whether the email exists
      const responseData = await response.json();
      successMessage = responseData.message;
    }
  } catch (error) {
    console.error("Forgot password error:", error);
    errorMessage = "An unexpected error occurred. Please check your connection.";
  }
}
---


<Layout>
    <main class="font-main flex justify-center">
        <div class="flex flex-col gap-5 max-w-2xl left-right-padding pt-24 lg:pt-20">
            <div class="flex justify-center pt-14 pb-2">
                <div class="flex flex-col items-center prose max-w-5xl text-center">
                    <Image src={LogoIcon} alt="" width=60 height=60 />
                    <h1 class="font-normal text-2xl mb-[0.3em]">
                         {translateLabels("signin.forgotPassword.title")}
                    </h1>
                    <p class="mt-0">{translateLabels("signin.forgotPassword.paragraph")}
                    </p>
                </div>
            </div>
            {errorMessage && (
                <div class="bg-red-50 text-red-600 p-3 rounded-md text-sm mb-4 text-center border border-red-100">
                    {translateLabels("signin.forgotPassword.error")}
                </div>
            )}

                {successMessage ? (
                    <div class="flex justify-center items-center gap-5 bg-green-50 text-green-700 p-6 rounded-md text-center font-medium border border-green-200">
                        <span class="text-sm">{translateLabels("signin.forgotPassword.success")}</span>
                    </div>
                    ) : (
                    <form method="POST" class="space-y-4">
                        <div>
                            <input
                                type="email"
                                id="email"
                                name="email"
                                required
                                placeholder={translateLabels("signin.forgotPassword.emailPlaceholder")}
                                class="w-full px-4 py-2 rounded-(--rounded-button) border border-(--border-color) focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-(--primary-color)"
                            />
                        </div>

                        <button type="submit" class="w-full py-2.5 px-3.5 mt-2 rounded-(--rounded-button) transition-colors ease-in-out no-underline bg-(--primary-color) hover:bg-(--secondary-color) text-white cursor-pointer">
                            {translateLabels("signin.forgotPassword.submitButton")}
                        </button>

                        <div class="text-center mt-4">
                            <a href="/signin" class="group text-sm text-gray-600 hover:underline">
                                  <Image src={LeftArrow} alt="Left Arrow" width=15 class="inline-block mt-0 mb-0 mr-1 transition-transform group-hover:-translate-x-0.5" />
                                  {translateLabels("signin.forgotPassword.back")}
                            </a>
                        </div>
                    </form>
                )}
        </div>
    </main>
</Layout>
