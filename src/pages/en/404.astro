---
import { getRelativeLocaleUrl, getAbsoluteLocaleUrl } from "astro:i18n";
import { useTranslation } from "../../i18n/utils"
import type { languageList } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";
import Image from 'astro/components/Image.astro'
import Logo from '../../assets/members_icon.svg'
import LeftArrow from '../../assets/left-arrow.svg'
const currentLang = Astro.currentLocale || 'en';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);
---

<Layout>
  <main class="font-main">
    <div class="flex flex-col gap-5 left-right-padding pt-24 lg:pt-20">
        <Image src={Logo} alt="" width=50 height=50 />
        <div>
            <h1>{translateLabels("404.title")}</h1>
            <p>{translateLabels("404.description")}</p>
            <a href="/" class="group mt-auto no-underline">
                <div class="flex gap-3 items-center">
                    <Image src={LeftArrow} alt="Left Arrow" width=15 class="inline-block mt-0 mb-0 mr-1" />
                    <p class="inline-block font-main relative after:content-[''] after:absolute after:right-0 after:bottom-0 after:h-px after:w-full after:bg-(--primary-color) after:scale-x-0 after:origin-left after:transition-transform after:duration-300 after:ease-out group-hover:after:scale-x-100">
                        {translateLabels("404.button")}
                    </p>
                </div>
            </a>
        </div>
    </div>
  </main>
</Layout>
