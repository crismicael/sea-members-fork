---
import { getAbsoluteLocaleUrl } from "astro:i18n";
import { useTranslation } from "../../i18n/utils"
import { API_URL } from 'astro:env/server';
import type { languageList } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";
import HeaderDashboard from "../../components/dashboard/HeaderDashboard.astro";
import FooterDashboard from "../../components/dashboard/FooterClientDashboard.astro";
import Image from 'astro/components/Image.astro'
import Language from "../../components/ui/Language.astro";
const currentLang = Astro.currentLocale || 'en';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);

type Coupon = {
  available_again_at?: string | null;
  name: string;
  description: string;
  img_url: string;
};


// 1. Get the custom JWT token from the user's cookies
const tokenCookie = Astro.cookies.get("client_jwt");

// 2. If the user isn't logged in, redirect them back to the login page
if (!tokenCookie) {
  return Astro.redirect("/signin");
}



const token = tokenCookie.value;

let profile = null;
let coupons: Coupon[] = [];

try {
  // 3. Fetch the Client Profile (Step 13 from our prompt)
  const profileResponse = await fetch(`${API_URL}/clients/me`, {
    method: "GET",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${token}` // Pass the JWT in the header
    }
  });

  if (profileResponse.status === 401) {
    // Token is invalid or expired
    Astro.cookies.delete("client_jwt");
    return Astro.redirect("/signin");
  }

  profile = await profileResponse.json();

  // 4. Fetch the Client's Coupons
  const couponsResponse = await fetch(`${API_URL}/clients/coupons`, {
    method: "GET",
    headers: {
      "Content-Type": "application/json",
      "Authorization": `Bearer ${token}`
    }
  });

  if (couponsResponse.ok) {
    coupons = await couponsResponse.json();
  }

} catch (error) {
  console.error("Error:", error);
}
---

<Layout>
  <HeaderDashboard />
  <main class="font-main">
    <div class="left-right-padding up-down-padding mx-auto pt-24 lg:pt-28 max-w-6xl border-x border-(--border-color) prose">
        <div class="flex justify-between">
            <h1 class="text-[22px] md:text-[2.25em]">{translateLabels("dashboard.welcome")}, {profile?.full_name ?? "User"}!</h1>
            <div id="client-dashboard-button-header">
                <Language color="black">
                    <span class="absolute inline-flex items-center justify-center h-full w-full rounded-full -top-3 -right-3 bg-black text-white text-[12px]">{translateLabels("footer.languageIcon")}</span>
                </Language>
            </div>
            <div id="client-dashboard-popper-header" role="tooltip" class="hidden z-30">
                <div class="popover-content w-48 p-4 bg-white border border-gray-300 rounded-[10px] shadow-lg flex flex-col">
                    <a href="/en/dashboard" class="no-underline flex gap-3 py-2 px-3 rounded-[10px] hover:bg-gray-500/10"><span class="font-bold uppercase">en</span><span>English</span></a>
                    <a href="/dashboard" class="no-underline flex gap-3 py-2 px-3 rounded-[10px] hover:bg-gray-500/10"><span class="font-bold uppercase">es</span><span>Español</span></a>
                </div>
            </div>
        </div>
        <p class="font-main">{translateLabels("dashboard.introduction")}</p>
        <p class="border-t mt-0 mb-0 py-[1.25em]  border-(--border-color) font-main">{translateLabels("dashboard.subtitle")}:
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 3xl:grid-cols-4 gap-4">
            {coupons.length === 0 ? (
                        <p>No coupons available at this time.</p>
                    ) : (
                        coupons.map((coupon: Coupon) => {
                            // Check the cooldown state returned by FastAPI
                            const now = new Date();
                            const availableAgain = coupon.available_again_at
                            ? new Date(coupon.available_again_at)
                            : null;
                            const isOnCooldown = availableAgain && availableAgain > now;

                            return isOnCooldown ? (
                            <div>
                                <div class="relative">
                                    <Image src={coupon.img_url} alt={coupon.name} width="500" height="500" draggable="false" class="rounded-2xl m-0 grayscale-100 blur-xs" />
                                    <strong class="absolute inset-0 flex flex-col items-center justify-center text-white text-center px-4">
                                    <span>{translateLabels("dashboard.coupons.notAvailable")}</span>
                                    <span>
                                        {availableAgain.toLocaleDateString()} at{" "}
                                        {availableAgain.toLocaleTimeString()}
                                    </span>
                                    </strong>
                                </div>
                                <div>
                                    <h4>{coupon.name}</h4>
                                    <p>{coupon.description}</p>
                                </div>
                            </div>
                            ) : (
                            <div>
                                <div>
                                    <Image src={coupon.img_url} alt={coupon.name} width="500" height="500" draggable="false" class="rounded-2xl m-0" />
                                </div>
                                <div>
                                    <h4>{coupon.name}</h4>
                                    <p>{coupon.description}</p>
                                </div>
                            </div>
                            );
                        })
                    )}
        </div>
    </div>
  </main>
  <FooterDashboard />
  <script>
      import { createPopper } from "@popperjs/core";

      const button = document.getElementById("client-dashboard-button-header");
      const popper = document.getElementById("client-dashboard-popper-header");

      let popperInstance: ReturnType<typeof createPopper> | null = null;
      let hideTimeout: ReturnType<typeof setTimeout> | null = null;

      function show() {
          if (!button || !popper) return;

          if (hideTimeout) {
              clearTimeout(hideTimeout);
              hideTimeout = null;
          }

          popper.classList.remove("hidden");
          popperInstance = createPopper(button, popper, {
              placement: "left-start",
              modifiers: [
                  {
                      name: "offset",
                      options: {
                          offset: [0, 8],
                      },
                  },
              ],
          });
      }

      function hide() {
          if (!popper) return;

          hideTimeout = setTimeout(() => {
              popper.classList.add("hidden");

              if (popperInstance) {
                  popperInstance.destroy();
                  popperInstance = null;
              }
          }, 100);
      }

      if (button && popper) {
          button.addEventListener('mouseenter', show);
          button.addEventListener('mouseleave', hide);
          popper.addEventListener('mouseenter', show);
          popper.addEventListener('mouseleave', hide);
      }
  </script>
</Layout>
