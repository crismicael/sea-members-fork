---
import { getAbsoluteLocaleUrl } from "astro:i18n";
import { useTranslation } from "../../i18n/utils"
import { API_URL } from 'astro:env/server';
import type { languageList } from "../../i18n/ui";
import Layout from "../../layouts/Layout.astro";
import HeaderRedeemDashboard from "../../components/dashboard/HeaderRedeemDashboard.astro";
const currentLang = Astro.currentLocale || 'en';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);

type Coupon = {
  id: string;
  description: string;
  cooldown_days: number;
  is_active: boolean;
};

const tokenCookie = Astro.cookies.get("business_jwt");
if (!tokenCookie) {
  return Astro.redirect("/business/signin");
}
const token = tokenCookie.value;

let profile = null;
let coupons: Coupon[] = [];
let errorMessage = "";
let successMessage = "";

try {
  // 1. Fetch profile for the navigation bar
  const profileResponse = await fetch(`${API_URL}/businesses/me`, {
    headers: { "Authorization": `Bearer ${token}` }
  });
  if (profileResponse.status === 401) return Astro.redirect("/business/signin");
  profile = await profileResponse.json();

  // 2. Fetch active coupons to populate the dropdown menu
  const couponsResponse = await fetch(`${API_URL}/businesses/coupons`, {
    headers: { "Authorization": `Bearer ${token}` }
  });
  if (couponsResponse.ok) {
    const allCoupons = await couponsResponse.json();
    // Only show active coupons in the dropdown
    coupons = allCoupons.filter((c: Coupon) => c.is_active);
  }

  // 3. Handle the form submission when a coupon is redeemed
  if (Astro.request.method === "POST") {
    const data = await Astro.request.formData();
    const ulid_code = data.get("ulid_code");
    const promotion_id = data.get("promotion_id");

    const redeemResponse = await fetch(`${API_URL}/businesses/redeem`, {
      method: "POST",
      headers: {
        "Content-Type": "application/json",
        "Authorization": `Bearer ${token}`
      },
      body: JSON.stringify({
        ulid_code: ulid_code,
        promotion_id: promotion_id
      })
    });

    if (!redeemResponse.ok) {
      errorMessage = translateLabels('redeem.error');
    } else {
      successMessage = translateLabels('redeem.success');
    }
  }
} catch (error) {
  errorMessage = "An unexpected error occurred.";
}
---

<Layout>
  <HeaderRedeemDashboard />
  <main class="font-main">
    <script is:inline src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
    <div class="left-right-padding up-down-padding mx-auto pt-24 lg:pt-28 max-w-6xl border-x border-(--border-color) prose">

        <!-- Messages -->
            {errorMessage && <div class="mb-6 p-4 bg-red-50 text-red-700 border border-red-200 rounded-md font-medium">{errorMessage}</div>}
            {successMessage && <div class="mb-6 p-4 bg-green-50 text-green-700 border border-green-200 rounded-md font-medium">{successMessage}</div>}

            <div class="grid grid-cols-1 gap-8">

                <div class="bg-white p-6 rounded-(--rounded-button) border border-(--border-color)">
                    <h2 class="text-lg font-bold mb-4">{translateLabels("redeem.qr.title")}</h2>
                    <p class="text-sm text-gray-500 mb-4">{translateLabels("redeem.qr.description")}</p>

                    <!-- The scanner will mount inside this div -->
                    <div id="reader" class="w-full overflow-hidden rounded-md border-2 border-dashed border-(--border-color) mb-4"></div>

                    <div id="scan-success-alert" class="hidden bg-blue-50 text-green-700 p-3 rounded text-sm font-medium text-center border border-blue-200">
                    {translateLabels("redeem.qr.success")}
                    </div>
                </div>
            </div>
            <div class="bg-white p-6 rounded-(--rounded-button) border border-(--border-color) mt-5">
                <h2 class="text-lg font-bold mb-4">{translateLabels("redeem.form.title")}</h2>

                <form method="POST" class="space-y-6">

                    <div>
                    <label for="ulid_code" class="block text-sm font-medium text-gray-700 mb-1">{translateLabels("redeem.form.labels.01.label")}</label>
                    <!-- Populated by the JS scanner below -->
                    <input
                        type="text"
                        id="ulid_code"
                        name="ulid_code"
                        required
                        readonly
                        placeholder={translateLabels("redeem.form.labels.01.placeholder")}
                        class="w-full px-4 py-2 bg-gray-50 border border-gray-300 rounded-md text-gray-500 focus:outline-none"
                    />
                    </div>

                    <div>
                        <label for="promotion_id" class="block text-sm font-medium text-gray-700 mb-1">{translateLabels("redeem.form.labels.02.label")}</label>
                        <select
                            id="promotion_id"
                            name="promotion_id"
                            required
                            class="w-full px-4 py-2 rounded-(--rounded-button) border border-(--border-color) focus-visible:outline-2 focus-visible:-outline-offset-1 focus-visible:outline-(--primary-color)"
                        >
                            <option value="" disabled selected>{translateLabels("redeem.form.labels.02.placeholder")}</option>
                            {coupons.map((coupon: Coupon) => (
                            <option value={coupon.id}>{coupon.description} ({coupon.cooldown_days}-day cooldown)</option>
                            ))}
                        </select>
                    </div>

                    <button
                    type="submit"
                    class="w-full py-2.5 px-3.5 mt-2 rounded-(--rounded-button) transition-colors ease-in-out no-underline bg-(--primary-color) hover:bg-(--secondary-color) text-white cursor-pointer"
                    >
                        {translateLabels("redeem.form.button")}
                    </button>

                </form>
            </div>
        </div>
    </main>

<script is:inline>
document.addEventListener("DOMContentLoaded", () => {
    const html5QrcodeScanner = new Html5QrcodeScanner(
    "reader",
    { fps: 10, qrbox: {width: 250, height: 250},
      videoConstraints: {
            facingMode: "environment"
    }},
    /* verbose= */ false
    );

    // When a QR code is successfully read
    function onScanSuccess(decodedText, decodedResult) {
    // 1. Put the scanned text into the read-only input field
    document.getElementById('ulid_code').value = decodedText;

    // 2. Show the success banner
    document.getElementById('scan-success-alert').classList.remove('hidden');

    // 3. Temporarily pause the scanner so it doesn't keep firing
    html5QrcodeScanner.pause();

    // Provide feedback to the receptionist
    }

    function onScanFailure(error) {
    // Ignore failures, it fires constantly until a code is found
    }

    html5QrcodeScanner.render(onScanSuccess, onScanFailure);
});
</script>
</Layout>
