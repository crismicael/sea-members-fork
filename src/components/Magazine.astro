---
import { useTranslation } from "../i18n/utils"
import type { languageList } from "../i18n/ui";
import Image from 'astro/components/Image.astro'
import TitaImage from '../assets/magazine-img.webp'
const currentLang = Astro.currentLocale || 'es';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);
---


<section id="magazine" class="bg-(--secondary-bg-color) border-y border-(--border-color) ">
    <div class="left-right-padding py-9 border-x border-(--border-color)">
        <div class="pt-14">
            <div class="grid grid-cols-1 xl:grid-cols-2 gap-5 justify-between">
                <div class="prose">
                    <h2 class="font-normal pt-10">
                        {translateLabels("magazine.title.line1")}
                        <span class="text-(--secondary-color)">
                            {translateLabels("magazine.title.line2")}
                        </span>
                    </h2>
                    <p>{translateLabels("magazine.description")}</p>
                </div>
                <div class="flex justify-center xl:justify-end">
                    <Image src={TitaImage} alt="Seaview Magazine" class="rounded-(--rounded-button)" />
                </div>
            </div>
        </div>
    </div>
</section>
