---
import Image from 'astro/components/Image.astro'
import Aquaventuras from '../assets/logos/046-Aquaventuras.png'
import Tosca from '../assets/logos/026-LaTosca.png'
import Mares from '../assets/logos/025-4Mares.png'
import Aurea from '../assets/logos/048-Aurea.png'
import Emmas from '../assets/logos/010-Emmas.png'
import Paty from '../assets/logos/045-Paty.png'
import SiempreDiva from '../assets/logos/029-SiempreDiva.png'
import Diosa from '../assets/logos/040-Diosa.png'
import Bichos from '../assets/logos/031-Bichos.png'
import Happy from '../assets/logos/054-Happy.png'
import Hera from '../assets/logos/062-Hera.png'
import Dannys from '../assets/logos/006-Dannys.png'
import Chinelo from '../assets/logos/014-Chinelo.png'
import Blessed from '../assets/logos/011-Blessed.png'

const logos = [
  { src: Chinelo, alt: 'Chinelo Logo' },
  { src: Hera, alt: 'Hera Logo' },
  { src: Blessed, alt: 'Blessed Logo' },
  { src: Emmas, alt: 'Emmas Logo' },
  { src: Tosca, alt: 'Tosca Logo' },
  { src: Aquaventuras, alt: 'Sea View Magazine Logo' },
  { src: Mares, alt: 'Mares Logo' },
  { src: Paty, alt: 'Paty Logo' },
  { src: SiempreDiva, alt: 'SiempreDiva Logo' },
  { src: Aurea, alt: 'Aurea Logo' },
  { src: Diosa, alt: 'Cafe La Diosa Logo' },
  { src: Bichos, alt: 'Bichos Logo' },
  { src: Dannys, alt: 'Dannys Logo' },
  { src: Happy, alt: 'Happy Logo' },
];

const carouselLogos = [...logos];
---

<section class="mx-8 sm:mx-32 3xl:mx-32 border-x border-(--border-color)" aria-label="Brand carousel">
    <div class="brand-carousel bg-(--secondary-color) py-6">
        <div class="brand-carousel__track">
            <ul class="brand-carousel__list" role="list">
              {carouselLogos.map((logo) => (
                <li class="brand-carousel__logo">
                  <Image src={logo.src} alt={logo.alt} class="brand-carousel__image" />
                </li>
              ))}
            </ul>
            <ul class="brand-carousel__list" role="list">
              {carouselLogos.map((logo) => (
                <li class="brand-carousel__logo">
                  <Image src={logo.src} alt={logo.alt} class="brand-carousel__image" />
                </li>
              ))}
            </ul>
        </div>

    </div>
</section>

<script is:inline>
(() => {
  const track = document.querySelector('.brand-carousel__track');
  if (!track) return;
  const list = track.querySelector('.brand-carousel__list');
  if (!list) return;

  const updateWidth = () => {
    const width = list.getBoundingClientRect().width;
    track.style.setProperty('--brand-carousel-list-width', `${width}px`);
  };

  updateWidth();
  const observer = new ResizeObserver(updateWidth);
  observer.observe(list);
  window.addEventListener('load', updateWidth);
})();
</script>

<style>
:global(:root) {
  --brand-carousel-duration: 28s;
  --brand-carousel-gap: 3.5rem;
  --brand-carousel-list-width: 0px;
}

.brand-carousel {
  position: relative;
  overflow: hidden;
  width: 100%;
}

.brand-carousel__track {
  display: flex;
  width: max-content;
  animation: brand-marquee var(--brand-carousel-duration) linear infinite;
}

.brand-carousel__list {
  display: flex;
  align-items: center;
  gap: var(--brand-carousel-gap);
  padding: 0 1.5rem;
  margin: 0;
  list-style: none;
}

.brand-carousel__logo {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
}

.brand-carousel__image {
  height: 50px;
  width: auto;
}

@keyframes brand-marquee {
  0% {
    transform: translateX(0%);
  }
  100% {
    transform: translateX(calc(-1 * var(--brand-carousel-list-width)));
  }
}

@media (prefers-reduced-motion: reduce) {
  .brand-carousel__track {
    animation: none;
  }
}
</style>
