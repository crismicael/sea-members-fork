  overflow-x: hidden;
}

.startup-carousel {
  width: 100%;
  padding: 3rem 0;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.startup-carousel__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1.5rem;
}

.startup-carousel__eyebrow {
  text-transform: uppercase;
  letter-spacing: 0.2em;
  font-size: 0.7rem;
  font-weight: 600;
  color: rgba(15, 23, 42, 0.55);
  margin: 0 0 0.5rem 0;
}

/*.startup-carousel__title {
  font-size: clamp(1.6rem, 2.5vw, 2.4rem);
  margin: 0;
  color: #0f172a;
  max-width: 36rem;
}*/

.startup-carousel__controls {
  display: flex;
  gap: 0.75rem;
}

.startup-carousel__button {
  width: 40px;
  height: 40px;
  border-radius: var(--rounded-button);
  border: 1px solid rgba(15, 23, 42, 0.12);
  background: white;
  color: #0f172a;
  font-size: 1.5rem;
  line-height: 1;
  cursor: pointer;
  transition: transform 200ms ease, box-shadow 200ms ease;
}

.startup-carousel__button:hover {
  transform: translateY(-1px);
  box-shadow: 0 6px 20px rgba(15, 23, 42, 0.12);
}

.startup-carousel__mask {
  width: 100%;
  overflow: hidden;
  cursor: grab;
  touch-action: pan-y;
  user-select: none;
}

.startup-carousel.is-dragging .startup-carousel__mask {
  cursor: grabbing;
}

.startup-carousel__track {
  display: flex;
  gap: var(--carousel-gap);
  transition: transform 500ms ease;
}

.startup-carousel__slide {
  min-width: 332px;
  max-width: 332px;
  width: 332px;
  flex: 0 0 332px;
  transition: transform 500ms ease, opacity 500ms ease;
  opacity: 1s;
  transform: scale(0.96);
}

.startup-carousel__slide[data-active="true"] {
  transform: scale(1);
}

.startup-carousel__card {
  display: grid;
  gap: 1rem;
}

.startup-carousel__media {
  border-radius: 16px;
  overflow: hidden;
  /*aspect-ratio: 332 / 448;*/
}

.startup-carousel__media-image {
  width: 100%;
  height: 100%;
  object-fit: contain;
  display: block;
}

.startup-carousel__meta {
  display: grid;
  gap: 0.5rem;
}

.startup-carousel__brand {
  margin: 0;
  font-weight: 600;
  color: #0f172a;
}

.startup-carousel__copy {
  margin: 0;
  color: rgba(15, 23, 42, 0.7);
  line-height: 1.5;
}

.startup-carousel__link {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-weight: 600;
  color: var(--primary-color);
  text-decoration: none;
}

.startup-carousel__link span {
  transition: transform 200ms ease;
}

.startup-carousel__link:hover span {
  transform: translateX(4px);
}

.startup-carousel__dots {
  display: flex;
  gap: 0.5rem;
  margin-top: auto;
}

.startup-carousel__dot {
  width: 26px;
  height: 4px;
  border-radius: 999px;
  border: none;
  background: rgba(15, 23, 42, 0.15);
  cursor: pointer;
}

.startup-carousel__dot[aria-pressed="true"] {
  background: var(--accent-color);
}

@media (max-width: 639px) {
  .startup-carousel__mask {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x proximity;
    -webkit-overflow-scrolling: touch;
    touch-action: pan-x;
    scrollbar-width: none;
  }

  .startup-carousel__track {
    width: 100%;
    box-sizing: border-box;
    /*padding: 0 1rem;*/
  }

  .startup-carousel__mask::-webkit-scrollbar {
    display: none;
  }

  .startup-carousel__slide {
    width: 70%;
    min-width: 70%;
    max-width: 70%;
    flex: 0 0 70%;
    scroll-snap-align: start;
    scroll-snap-stop: always;
  }

  .startup-carousel__dots {
      justify-content: center;
  }

  .startup-carousel__dot {
    width: 8px;
    height: 4px;
  }
}

@media (max-width: 720px) {
  .startup-carousel__header {
    flex-direction: column;
    align-items: flex-start;
  }
}
