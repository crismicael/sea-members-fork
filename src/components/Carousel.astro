  },
  {
    brand: translateLabels("carousel.carouselItems.11.brand"),
    description: translateLabels("carousel.carouselItems.11.description"),
    cta: translateLabels("carousel.carouselItems.11.cta"),
    href: "#",
    image: VipsPromoTwo
  },
  {
    brand: translateLabels("carousel.carouselItems.12.brand"),
    description: translateLabels("carousel.carouselItems.12.description"),
    cta: translateLabels("carousel.carouselItems.12.cta"),
    href: "#",
    image: HappyFeetsPromo
  },
