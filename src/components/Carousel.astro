    href: "#",
    image: MultiMedicaPromoTwo
  },
  {
    brand: translateLabels("carousel.carouselItems.08.brand"),
    description: translateLabels("carousel.carouselItems.08.description"),
    cta: translateLabels("carousel.carouselItems.08.cta"),
    href: "#",
    image: OsojiPromo
  },
  {
    brand: translateLabels("carousel.carouselItems.09.brand"),
    description: translateLabels("carousel.carouselItems.09.description"),
