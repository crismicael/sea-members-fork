---
import { getRelativeLocaleUrl } from "astro:i18n";
import { useTranslation } from "../i18n/utils"
import type { languageList } from "../i18n/ui";
import Image from 'astro/components/Image.astro'
import Logo from '../assets/members_icon.svg'
import Language from "./ui/Language.astro";
import Card from '../assets/members_hero.png'
import Button from './shared/Button.astro'
import ButtonArrow from './shared/ButtonArrow.astro'
import SeaViewLogo from '../assets/seaviewmagazine_logo.png'
const currentLang = Astro.currentLocale || 'es';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);

// Helper function for locale-aware hash navigation
const getHashUrl = (hash: string) => {
    // If we're on the homepage, use hash only
    if (Astro.url.pathname === '/' || Astro.url.pathname === `/${currentLang}/`) {
        return hash;
    }
    // Otherwise, go to localized homepage with hash
    return getRelativeLocaleUrl(currentLang, `/`) + hash;
};
---

<section id="hero" class="left-right-padding up-down-padding pt-24 lg:pt-28 px-4 mx-0 md:px-6 md:mx-8 lg:mx-32 3xl:mx-56 border-0 md:border-x md:border-b md:border-(--border-color)">
    <div class="flex flex-col md:flex-row gap-8 items-start md:items-center justify-center">
        <div class="flex flex-col gap-10 font-light">
            <div class="flex gap-3 justify-between">
                <div class="flex gap-3 item-center">
                    <span>{translateLabels("hero.subtitle")}</span>
                    <a href="https://seaviewmagazine.com/" target="_blank">
                        <Image src={SeaViewLogo} width=70 alt="Logo de Sea View Magazine" />
                    </a>
                    <!-- just a little easter egg -->
                </div>
                <div class="block sm:hidden pe-3">
                    <div id="language-button-hero">
                        <Language color="black">
                            <span class="absolute inline-flex items-center justify-center h-full w-full rounded-full -top-3 -right-3 bg-black text-white text-[12px]">{translateLabels("footer.languageIcon")}</span>
                        </Language>
                    </div>
                    <div id="language-popper-hero" role="tooltip" class="hidden z-50">
                        <div class="popover-content w-48 p-4 bg-white border border-gray-300 rounded-[10px] shadow-lg flex flex-col">
                            <a href="/en" class="flex gap-3 py-2 px-3 rounded-[10px] hover:bg-gray-500/10"><span class="font-bold uppercase">en</span><span>English</span></a>
                            <a href="/" class="flex gap-3 py-2 px-3 rounded-[10px] hover:bg-gray-500/10"><span class="font-bold uppercase">es</span><span>Español</span></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="prose max-w-lg">
                <h1 class="font-normal text-3xl md:text-4xl">{translateLabels("hero.title.line1")}
                <span class="text-(--primary-color) font-normal text-3xl md:text-4xl">
                    {translateLabels("hero.title.line2")}
                </span>
                <div class="flex flex-col">
                    <ul class="pl-0 text-sm *:font-main">
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" class="mt-0 mb-0"  />
                            {translateLabels("hero.title.bulletPoints.01")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" class="mt-0 mb-0" />
                            {translateLabels("hero.title.bulletPoints.02")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" class="mt-0 mb-0" />
                            {translateLabels("hero.title.bulletPoints.03")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" class="mt-0 mb-0" />
                            {translateLabels("hero.title.bulletPoints.04")}
                        </li>
                    </ul>
                </div>

            </div>
            <div class="flex flex-col sm:flex-row gap-2 items-stretch sm:items-center font-semibold">
                <ButtonArrow href={getHashUrl("#prices")} text={translateLabels("hero.buttonArrowHero")} className="px-6 py-2.5 w-full sm:w-auto" />
                <Button href={getHashUrl("#prices")} text={translateLabels("hero.buttonHero")} className="px-2 md:px-2 2xl:px-16 py-2.5 w-full sm:w-auto" >
                    <Image src={Logo} alt="Members Logo" width="30" height="30" draggable="false" />
                </Button>
            </div>
        </div>
        <div class="flex justify-center md:justify-end w-full md:w-auto">
            <Image src={Card} alt="placeholder" width=400 class="max-w-full h-auto" />
        </div>
    </div>
</section>

<script>
    import { createPopper } from "@popperjs/core";

    const button = document.getElementById("language-button-hero");
    const popper = document.getElementById("language-popper-hero");

    let popperInstance: any = null;
    let hideTimeout: ReturnType<typeof setTimeout> | null = null;

    function show() {
        if (hideTimeout) {
            clearTimeout(hideTimeout);
            hideTimeout = null;
        }
        popper?.classList.remove("hidden");
        popperInstance = createPopper(button, popper, {
            placement: "left",
            modifiers: [
                {
                    name: "offset",
                    options: {
                        offset: [0, 8],
                    },
                },
            ],
        });
    }

    function hide() {
        hideTimeout = setTimeout(() => {
            popper?.classList.add("hidden");

            if (popperInstance) {
                popperInstance.destroy();
                popperInstance = null;
            }
        }, 100);
    }

    button?.addEventListener('mouseenter', show);
    button?.addEventListener('mouseleave', hide);
    popper?.addEventListener('mouseenter', show);
    popper?.addEventListener('mouseleave', hide);
</script>
