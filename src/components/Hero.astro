---
import Image from 'astro/components/Image.astro'
import Logo from '../assets/members_icon.svg'
import Card from '../assets/members_hero.png'
import Button from './shared/Button.astro'
import ButtonArrow from './shared/ButtonArrow.astro'
import SeaViewLogo from '../../public/seaviewmagazine_logo.png'
---

<section id="hero" class="left-right-padding up-down-padding pt-24 xl:pt-16 px-4 mx-0 md:px-6 md:mx-8 lg:mx-32 3xl:mx-32 border-0 md:border-x md:border-b md:border-(--border-color)">
    <div class="flex flex-col md:flex-row gap-8 items-start md:items-center justify-center">
        <div class="flex flex-col gap-10 font-light">
            <div class="flex gap-3 item-center ">
                <span>Un producto de: </span>
                <a href="https://seaviewmagazine.com/" target="_blank">
                    <Image src={SeaViewLogo} width=70 alt="Logo de Sea View Magazine" />
                </a>
            </div>
            <div class="prose">
                <h1 class="font-normal">Members es el nuevo programa de suscripciones con beneficios exclusivos de
                <span class="text-(--primary-color) font-semibold">
                    Seaview Grupo Editorial
                </span>
                para residentes y visitantes de Puerto Vallarta.</h1>
            </div>
            <div class="flex flex-col sm:flex-row gap-2 items-stretch sm:items-center font-bold">
                <ButtonArrow href="/#prices" text="Suscríbete" className="px-6 py-2.5 w-full sm:w-auto" />
                <Button href="/#prices" text="Conoce los beneficios" className="px-2 md:px-2 2xl:px-16 py-2.5 w-full sm:w-auto" >
                    <Image src={Logo} alt="Members Logo" width="30" height="30" draggable="false" />
                </Button>
            </div>
        </div>
        <div class="flex justify-center md:justify-end w-full md:w-auto">
            <Image src={Card} alt="placeholder" width=400 class="max-w-full h-auto" />
        </div>
    </div>
</section>
