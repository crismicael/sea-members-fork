---
import { useTranslation } from "../i18n/utils"
import type { languageList } from "../i18n/ui";
import Image from 'astro/components/Image.astro'
import Logo from '../assets/members_icon.svg'
import Arrow from './ui/Arrow.astro'
const currentLang = Astro.currentLocale || 'es';
const translateLabels = useTranslation(currentLang as keyof typeof languageList);
---

<section id="prices" class="left-right-padding up-down-padding border-x border-b border-(--border-color)">
    <div class="flex flex-col gap-6">
        <div class="flex pt-14">
            <div class="prose">
                <h2 class="font-normal">
                    {translateLabels("prices.title.line1")}<span class="text-(--secondary-color)">{translateLabels("prices.title.line2")}</span>{translateLabels("prices.title.line3")}
                </h2>
            </div>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-3 border border-(--border-color) rounded-(--rounded-button) overflow-hidden divide-y md:divide-y-0 md:divide-x divide-(--border-color) divide-dashed">
            <article class="p-6 text-(--header-color)">
                <div class="flex flex-col gap-3">
                    <div class="px-4 py-2">
                        <p class="font-semibold text-(--header-color) leading-snug">
                            {translateLabels("prices.pricesGrid.01.title")}
                        </p>
                    </div>
                    <ul class="pl-5">
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false"  />
                            {translateLabels("prices.pricesGrid.01.bulletPoint1")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.01.bulletPoint2")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.01.bulletPoint3")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.01.bulletPoint4")}
                        </li>
                    </ul>
                </div>
            </article>
            <article class="p-6 text-(--header-color)">
                <div class="flex flex-col gap-3">
                    <div class="px-4 py-2">
                        <p class="font-semibold text-(--header-color) leading-snug">
                            {translateLabels("prices.pricesGrid.02.title")}
                        </p>
                    </div>
                    <ul class="list-disc pl-5">
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.02.bulletPoint1")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.02.bulletPoint2")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.02.bulletPoint3")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.02.bulletPoint4")}
                        </li>
                        <!-- <li class="flex items-baseline pt-5">
                            <a href="" class="group mt-auto no-underline">
                                <div class="flex gap-3 items-center">
                                    <p class="inline-block font-main text-(--primary-color) hover:text-(--secondary-color)  relative after:content-[''] after:absolute after:right-0 after:bottom-0 after:h-px after:w-full after:bg-(--primary-color) after:scale-x-0 after:origin-left after:transition-transform after:duration-300 after:ease-out group-hover:after:scale-x-100">
                                        {translateLabels("prices.pricesGrid.02.button")}
                                    </p>
                                    <Arrow className="text-(--primary-color) transition-transform duration-300 ease-out will-change-transform group-hover:translate-x-1" />
                                </div>
                            </a>
                        </li> -->
                    </ul>
                </div>
            </article>
            <article id="suscribe" class="p-6 text-(--header-color)">
                <div class="flex flex-col gap-3">
                    <div class="px-4 py-2">
                        <p class="font-semibold text-(--header-color) leading-snug">
                            {translateLabels("prices.pricesGrid.03.title")}
                        </p>
                    </div>
                    <ul class="list-disc pl-5">
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.03.bulletPoint1")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.03.bulletPoint2")}
                        </li>
                        <li class="flex items-baseline gap-2">
                            <Image src={Logo} alt="Members Logo" width="20" height="20" draggable="false" />
                            {translateLabels("prices.pricesGrid.03.bulletPoint3")}
                        </li>
                    </ul>
                </div>
            </article>
        </div>
        <div class="flex flex-col sm:flex-row gap-3  justify-evenly items-stretch">
            <a href="https://buy.stripe.com/dRm8wH9eV5aPcmz7Wk1Jm07" class="group relative flex flex-1 flex-col items-center justify-center gap-1 px-6 py-4 transition-colors border border-(--secondary-color) rounded-(--rounded-button)">
                <span class="absolute right-3 top-3 transition-transform duration-200 ease-out group-hover:-translate-y-0.5 group-hover:translate-x-0.5 border border-(--border-color) rounded-(--rounded-button) p-1">
                    <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-(--header-color)" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"></path>
                    </svg>
                </span>
                <span class="text-sm line-through">
                    {translateLabels("prices.pricesButtons.01.before")}
                </span>
                <span class="text-2xl font-medium text-(--header-color)">
                    {translateLabels("prices.pricesButtons.01.newPrice")}
                </span>
                <span class="text-sm">
                    {translateLabels("prices.pricesButtons.01.subText")}
                </span>
            </a>
            <a href="https://buy.stripe.com/3cIaEP62JdHl2LZa4s1Jm06" class="group relative flex flex-1 flex-col items-center justify-center gap-1 px-6 py-4 transition-colors bg-(--secondary-color)/30 border border-(--border-color) rounded-(--rounded-button)">
                <span class="absolute right-3 top-3 transition-transform duration-200 ease-out group-hover:-translate-y-0.5 group-hover:translate-x-0.5 border border-(--secondary-color) rounded-(--rounded-button) p-1">
                    <svg fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-4 text-(--header-color)" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25"></path>
                    </svg>
                </span>
                <span class="text-sm line-through">
                    {translateLabels("prices.pricesButtons.02.before")}
                </span>
                <span class="text-2xl font-medium text-(--header-color)">
                    {translateLabels("prices.pricesButtons.02.newPrice")}
                </span>
                <span class="text-sm">
                    {translateLabels("prices.pricesButtons.02.subText")}
                </span>
            </a>
        </div>
    </div>
</section>
